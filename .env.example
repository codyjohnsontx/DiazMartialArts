# Public site URL. Must include protocol in Preview/Production.
NEXT_PUBLIC_SITE_URL=https://diazmartialarts.vercel.app
# Public Google Calendar embed URL for /schedule monthly calendar.
NEXT_PUBLIC_GOOGLE_CALENDAR_EMBED_URL=
# Public ICS feed URL for /schedule upcoming events fallback.
NEXT_PUBLIC_GOOGLE_CALENDAR_ICS_URL=
# Public Formspree endpoint URL for contact form submissions.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
# Clerk publishable key (safe for client exposure).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clerk secret key (server-side only).
CLERK_SECRET_KEY=
# Base URL for the separate Diaz on Demand VOD app.
NEXT_PUBLIC_ONDEMAND_URL=https://ondemand.diazmartialarts.com
# Optional server-side entitlements API URL.
DIAZ_ENTITLEMENTS_API_URL=
# Optional server-side entitlements API key.
DIAZ_ENTITLEMENTS_API_KEY=
# Development-only entitlement fallback.
DEV_FORCE_VOD_ENTITLEMENT=false
